    {
      "name": "CreateToken",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has token\", function () {\r",
              "    const responseData = pm.response.json();\r",
              "    pm.expect(responseData).to.have.property('token');\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Save token to environment\", function () {\r",
              "    const responseData = pm.response.json();\r",
              "    const token = responseData.token;\r",
              "    \r",
              "    // Сохраняем в переменную окружения\r",
              "    pm.environment.set(\"token\", token);\r",
              "    \r",
              "    console.log(\"Token saved to environment:\", token);\r",
              "    console.log(\"You can now use {{token}} in other requests\");\r",
              "});"
            ],
